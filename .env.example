# Hardened baseline. Copy to .env and inject real values via the orchestrator/secrets manager.
# Never commit a real .env to source control.
NODE_ENV=production

# Shared auth service settings
JWT_SECRET=replace-with-random-base64-string-of-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ISSUER=healthcare-micro-clean
JWT_AUDIENCE=healthcare-internal
JWT_EXPIRY_SECONDS=3600

# Inter-service shared secret for service-to-service auth (mTLS would be preferred in prod)
SERVICE_TOKEN_SECRET=replace-with-shared-secret-or-use-mTLS

# Database credentials per service — injected at runtime
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth
AUTH_DB_USER=auth_app
AUTH_DB_PASSWORD=replace-with-secret-manager-reference

PATIENT_DB_HOST=patient-db
PATIENT_DB_PORT=5432
PATIENT_DB_NAME=patient
PATIENT_DB_USER=patient_app
PATIENT_DB_PASSWORD=replace-with-secret-manager-reference

APPOINTMENT_DB_HOST=appointment-db
APPOINTMENT_DB_PORT=5432
APPOINTMENT_DB_NAME=appointment
APPOINTMENT_DB_USER=appointment_app
APPOINTMENT_DB_PASSWORD=replace-with-secret-manager-reference

BILLING_DB_HOST=billing-db
BILLING_DB_PORT=5432
BILLING_DB_NAME=billing
BILLING_DB_USER=billing_app
BILLING_DB_PASSWORD=replace-with-secret-manager-reference

# Payment gateway key belongs in a secret manager
PAYMENT_GATEWAY_KEY=replace-with-secret-manager-reference
